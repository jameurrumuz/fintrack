{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postbuild": "npm run copy-static || echo 'Skipping copy-static on Vercel'",
    "copy-static": "if not exist .next\\standalone\\public mkdir .next\\standalone\\public && xcopy /E /I /Y public\\* .next\\standalone\\public\\ && if not exist .next\\standalone\\.next\\static mkdir .next\\standalone\\.next\\static && xcopy /E /I /Y .next\\static\\* .next\\standalone\\.next\\static\\",
    "vercel-build": "next build",
    "clean": "rmdir /S /Q .next 2>nul & rmdir /S /Q node_modules\\.cache 2>nul",
    "deploy": "npm run build && npm run postbuild && echo ✅ Build complete! Upload .next\\standalone folder to cPanel",
    "deploy:zip": "npm run build && npm run postbuild && powershell Compress-Archive -Path .next\\standalone\\* -DestinationPath deploy.zip -Force && echo ✅ deploy.zip created successfully!"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.14.0",
    "@genkit-ai/next": "1.14.0",
    "@hookform/resolvers": "4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-autoplay": "^8.1.5",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.1.0",
    "firebase-admin": "^12.0.0",
    "framer-motion": "^11.5.7",
    "genkit": "1.14.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.475.0",
    "next": "16.2.2",
    "papaparse": "^5.4.1",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "qrcode": "^1.5.3",
    "react": "19.0.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.52.1",
    "react-to-print": "^3.0.1",
    "recharts": "^2.15.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/recharts": "^1.8.29",
    "genkit-cli": "1.14.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "engines": {
    "node": "20.x || 22.x",
    "npm": ">=9.0.0"
  }
}
